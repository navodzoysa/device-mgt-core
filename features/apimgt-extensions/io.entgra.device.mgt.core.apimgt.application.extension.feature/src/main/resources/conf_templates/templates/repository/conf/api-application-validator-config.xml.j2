<ApiApplicationValidatorConfig>
    <Validators>
        {% if api_application_validator is defined %}
            {% for validator in api_application_validator %}
        <Validator>
            <MetadataKey>{{validator.metadata_key}}</MetadataKey>
            <ApiSearchQuery>{{validator.api_search_query}}</ApiSearchQuery>
        </Validator>
            {% endfor %}
        {% endif %}
    </Validators>
</ApiApplicationValidatorConfig>
